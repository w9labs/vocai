# ============================================================
# VOCAI: Vocab+AI — .env.example
# ============================================================

# Server Configuration
PORT=3010
RUST_LOG=info
VOCAI_BASE_URL=https://vocai.top

# Database (shared w9-postgres)
DATABASE_URL=postgres://w9_admin:PASSWORD@w9-postgres:5432/w9_vocabai

# NVIDIA AI API (text flashcards)
NVIDIA_API_KEY=nvapi-YOUR_API_KEY

# Pollinations AI API (images are generated only when saving a flashcard)
POLLINATIONS_API_KEY=sk-YOUR_API_KEY
POLLINATIONS_API_BASE=https://gen.pollinations.ai
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_IMAGE_SIZE=512x512
POLLINATIONS_IMAGE_QUALITY=medium

# OAuth (w9-db)
ISSUER_URL=https://db.w9.nu
OAUTH_CLIENT_ID=vocai
OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET
