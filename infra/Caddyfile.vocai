# ============================================================
# VOCAI: Vocab+AI — Caddy Route
# Already added on VPS at /etc/caddy/Caddyfile
#
# TLS: self-signed (tls internal) — Cloudflare handles public SSL
# Flow: User → HTTPS → Cloudflare → HTTP → Caddy → vocai:3010
# ============================================================

vocai.top {
    tls internal
    reverse_proxy vocai:3010
    encode gzip
}
